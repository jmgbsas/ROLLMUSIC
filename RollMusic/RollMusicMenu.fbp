[Project]
Version=3
Description=RollMusic Secuenciador con letras
Api=fb (FreeBASIC)
Grouping=1
AddMainFiles=0
AddModuleFiles=1
ResExport=
CompileIfNewer=1
IncVersion=1
RunCmd=0
[Make]
Module=Module Build,fbc64 appicon.rc -s gui -gen gas64 -fpu SSE -t 8192 -arch amd64  -exx -m RollMusic 
Recompile=2
Current=2
1=GAS Win Console (debug),fbc64   -g -s console -gen gas64 -exx
2=GAS GUI ,fbc64 appicon.rc -v -s gui -gen gas64 -fpu SSE -t 8192 -arch amd64 -exx -m RollMusic 
3=GAS GUI dbg  ,fbc64 appicon.rc -g -s gui  -gen gas64 -fpu SSE -t 8192 -arch amd64  -exx -m RollMusic
4=GCC Win Console,fbc64   -g -s console -t 8192 -exx
5=GCC GUI ,fbc64  -s gui -gen gcc  -fpu SSE -t 8192 -arch amd64 -exx -m RollMusic
6=GCC GUI dbg ,fbc64  -g -s gui -gen gcc -fpu SSE -t 8192 -arch amd64  -exx -m RollMusic
7=GCC GUI dbg gdwarf-4 ,fbc64 appicon.rc -v -g  -gen gcc -s gui -t 8192 -m RollMusic  -exx  -Wc -gdwarf-4 
8=GAS GUI PROFILE,fbc64  -profile -s gui  -gen gas64 -fpu SSE -t 8192 -arch amd64  -exx -m RollMusic
9=GCC GUI dbg NOOPT,fbc64 -v -g  -gen gcc -s gui -t 8192 -m RollMusic  -exx  -Wc -gdwarf-4 -Wc -Og -Wc -Wall
10=DBG gui,fbc64 -g -m RollMusic 
Output=..\RollMusic.exe
Run=
Delete=
